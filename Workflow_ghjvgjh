name: Обновление VPN конфигов

on:
  schedule:
    - cron: '*/30 * * * *'
  workflow_dispatch:
  push:
    branches: [ main ]

jobs:
  update-configs:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    
    steps:
    - name: Проверка репозитория
      uses: actions/checkout@v3
      
    - name: Скачивание и обработка конфигов
      run: |
        curl -s "https://raw.githubusercontent.com/igareck/vpn-configs-for-russia/refs/heads/main/BLACK_VLESS_RUS_mobile.txt" | head -n 20 > vpn_configs.txt
        
        echo "Сохранено $(wc -l < vpn_configs.txt) конфигов"
    
    - name: Коммит и пуш изменений
      run: |
        git config --global user.name 'GitHub Action'
        git config --global user.email 'action@github.com'
        git add vpn_configs.txt
        git diff --quiet && git diff --staged --quiet || (git commit -m "Автообновление конфигов $(date '+%Y-%m-%d %H:%M')" && git push)
